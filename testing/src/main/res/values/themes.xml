<resources>
    <style name="CustomSwitchStyle" parent="Theme.AppCompat.Light">
        <item name="colorControlActivated">#07C160</item>
        <item name="colorSwitchThumbNormal">#FFFFFF</item>
        <item name="android:colorForeground">#CCCCCC</item>
    </style>
    <style name="DialButton">
        <item name="android:layout_width">80dp</item>
        <item name="android:layout_height">80dp</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">#000000</item>
        <item name="android:background">@drawable/bg_dial_button</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
        <item name="android:gravity">center</item>
    </style>
    <style name="CallButton">
        <item name="android:layout_width">@dimen/call_button_width_height</item>
        <item name="android:layout_height">@dimen/call_button_width_height</item>
    </style>
    <style name="CallButtonText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/recent_item_second_font_size</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:layout_marginTop">4dp</item>
    </style>
</resources>